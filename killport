#!/usr/bin/env bash

set -euo pipefail

VERSION="1.4.0"
REPO="skosari/killport-linux"
RAW="https://raw.githubusercontent.com/${REPO}/main"

check_update() {
  local remote
  remote=$(curl -fsSL --max-time 2 "${RAW}/VERSION" 2>/dev/null | tr -d '[:space:]' || true)
  if [ -n "$remote" ] && [ "$remote" != "$VERSION" ]; then
    echo "  Update available: $VERSION → $remote  (run: killport update)"
    echo ""
  fi
}

list_ports() {
  echo "Listening ports:"
  echo ""
  if command -v ss &>/dev/null; then
    ss -tlnp | awk 'NR>1 {printf "  %-25s %-10s %s\n", $4, $1, $6}' | sort
  elif command -v lsof &>/dev/null; then
    lsof -iTCP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {printf "  %-8s %-10s %-10s %s\n", $9, $1, $2, $8}' | sort -t: -k2 -n
  fi
}

open_port() {
  local PORT=$1
  echo "Opening port $PORT to external connections..."
  if command -v ufw &>/dev/null && sudo ufw status | grep -q "Status: active"; then
    sudo ufw allow "$PORT" && echo "Port $PORT opened via ufw."
  elif command -v firewall-cmd &>/dev/null; then
    sudo firewall-cmd --add-port="${PORT}/tcp" --permanent
    sudo firewall-cmd --add-port="${PORT}/udp" --permanent
    sudo firewall-cmd --reload
    echo "Port $PORT opened via firewalld."
  elif command -v iptables &>/dev/null; then
    sudo iptables -I INPUT -p tcp --dport "$PORT" -j ACCEPT
    sudo iptables -I INPUT -p udp --dport "$PORT" -j ACCEPT
    echo "Port $PORT opened via iptables."
    echo "Note: run 'iptables-save' to persist across reboots."
  else
    echo "Error: no supported firewall found (ufw, firewalld, iptables)"
    exit 1
  fi
}

close_port() {
  local PORT=$1
  echo "Closing port $PORT from external connections..."
  if command -v ufw &>/dev/null && sudo ufw status | grep -q "Status: active"; then
    sudo ufw deny "$PORT" && echo "Port $PORT closed via ufw."
  elif command -v firewall-cmd &>/dev/null; then
    sudo firewall-cmd --remove-port="${PORT}/tcp" --permanent
    sudo firewall-cmd --remove-port="${PORT}/udp" --permanent
    sudo firewall-cmd --reload
    echo "Port $PORT closed via firewalld."
  elif command -v iptables &>/dev/null; then
    sudo iptables -D INPUT -p tcp --dport "$PORT" -j ACCEPT 2>/dev/null || true
    sudo iptables -D INPUT -p udp --dport "$PORT" -j ACCEPT 2>/dev/null || true
    sudo iptables -I INPUT -p tcp --dport "$PORT" -j DROP
    sudo iptables -I INPUT -p udp --dport "$PORT" -j DROP
    echo "Port $PORT closed via iptables."
    echo "Note: run 'iptables-save' to persist across reboots."
  else
    echo "Error: no supported firewall found (ufw, firewalld, iptables)"
    exit 1
  fi
}

which_port() {
  local PORT=$1
  echo "Port $PORT status:"
  echo ""

  # Firewall rule
  local fw_open=false
  if command -v ufw &>/dev/null && sudo ufw status 2>/dev/null | grep -qE "^${PORT}.*ALLOW"; then
    echo "  Firewall:  OPEN  (ufw allows external access)"
    fw_open=true
  elif command -v firewall-cmd &>/dev/null && sudo firewall-cmd --list-ports 2>/dev/null | grep -q "${PORT}/"; then
    echo "  Firewall:  OPEN  (firewalld allows external access)"
    fw_open=true
  elif command -v iptables &>/dev/null && sudo iptables -L INPUT -n 2>/dev/null | grep -q "dpt:${PORT}.*ACCEPT"; then
    echo "  Firewall:  OPEN  (iptables allows external access)"
    fw_open=true
  fi
  if ! $fw_open; then
    echo "  Firewall:  CLOSED  (no rule found allowing external access)"
  fi

  # Actively listening
  local PIDS=""
  if command -v ss &>/dev/null; then
    PIDS=$(ss -tlnp "sport = :$PORT" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | sort -u || true)
  elif command -v lsof &>/dev/null; then
    PIDS=$(lsof -ti :"$PORT" 2>/dev/null || true)
  fi
  if [ -n "$PIDS" ]; then
    local NAME
    NAME=$(echo "$PIDS" | head -1 | xargs -I{} ps -p {} -o comm= 2>/dev/null || true)
    echo "  Listening: YES  (PID: $(echo "$PIDS" | tr '\n' ' ')— $NAME)"
  else
    echo "  Listening: NO  (nothing is running on this port)"
  fi
}

show_ip() {
  echo "Network Interfaces"
  echo "────────────────────────────────────"
  if command -v ip &>/dev/null; then
    ip -o addr show | awk '
      {
        iface=$2; proto=$3; addr=$4
        if (proto == "link/ether") mac=addr
        else printf "  %-12s %-8s %s\n", iface, proto, addr
      }'
  else
    ifconfig | awk '/^[a-z]/{iface=$1} /inet /{print "  " iface "\t" $2} /inet6 /{print "  " iface "\t" $2}'
  fi

  echo ""
  echo "Default Gateway"
  echo "────────────────────────────────────"
  if command -v ip &>/dev/null; then
    ip route | awk '/^default/{print "  " $3; exit}'
  else
    netstat -rn | awk '/^0\.0\.0\.0/{print "  " $2; exit}'
  fi

  echo ""
  echo "DNS Servers"
  echo "────────────────────────────────────"
  if command -v resolvectl &>/dev/null; then
    resolvectl status 2>/dev/null | awk '/DNS Servers/{print "  " $3}'
  elif [ -f /etc/resolv.conf ]; then
    awk '/^nameserver/{print "  " $2}' /etc/resolv.conf
  fi

  echo ""
  echo "Firewall Status"
  echo "────────────────────────────────────"
  if command -v ufw &>/dev/null; then
    sudo ufw status 2>/dev/null | head -5 | sed 's/^/  /'
  elif command -v firewall-cmd &>/dev/null; then
    sudo firewall-cmd --list-ports 2>/dev/null | sed 's/^/  Open ports: /'
  elif command -v iptables &>/dev/null; then
    echo "  iptables rules:"
    sudo iptables -L INPUT --line-numbers 2>/dev/null | head -10 | sed 's/^/    /'
  fi
}

# -------------------------------------------------------

if [ $# -eq 0 ]; then
  echo "killport v${VERSION}"
  echo ""
  echo "  killport                   show this help and list listening ports"
  echo "  killport <port>            kill whatever is running on that port"
  echo "  killport list              list all listening ports"
  echo "  killport open <port>       open a port to external connections"
  echo "  killport close <port>      close a port from external connections"
  echo "  killport which <port>      show if a port is open or closed"
  echo "  killport ip                show IP addresses, DNS, and network info"
  echo "  killport update            update to the latest version"
  echo ""
  check_update
  list_ports
  exit 0
fi

case "$1" in

  update)
    echo "Checking for updates..."
    remote=$(curl -fsSL --max-time 5 "${RAW}/VERSION" 2>/dev/null | tr -d '[:space:]' || true)
    if [ -z "$remote" ]; then echo "Could not reach GitHub. Check your connection."; exit 1; fi
    if [ "$remote" = "$VERSION" ]; then echo "Already up to date (v${VERSION})"; exit 0; fi
    echo "Updating $VERSION → $remote..."
    INSTALL_PATH=$(command -v killport)
    if [ -w "$INSTALL_PATH" ]; then
      curl -fsSL "${RAW}/killport" -o "$INSTALL_PATH" && chmod +x "$INSTALL_PATH"
    else
      sudo curl -fsSL "${RAW}/killport" -o "$INSTALL_PATH" && sudo chmod +x "$INSTALL_PATH"
    fi
    echo "Updated to v${remote}. Run killport to confirm."
    ;;

  list)
    list_ports
    ;;

  which)
    [ -z "${2:-}" ] && { echo "Usage: killport which <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    which_port "$2"
    ;;

  ip)
    show_ip
    ;;

  open)
    [ -z "${2:-}" ] && { echo "Usage: killport open <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    open_port "$2"
    ;;

  close)
    [ -z "${2:-}" ] && { echo "Usage: killport close <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    close_port "$2"
    ;;

  *)
    PORT="$1"
    if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
      echo "Error: '$PORT' is not a valid port number (1–65535)"
      exit 1
    fi
    if command -v ss &>/dev/null; then
      PIDS=$(ss -tlnp "sport = :$PORT" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | sort -u || true)
    elif command -v lsof &>/dev/null; then
      PIDS=$(lsof -ti :"$PORT" 2>/dev/null || true)
    elif command -v fuser &>/dev/null; then
      PIDS=$(fuser "${PORT}/tcp" 2>/dev/null | tr ' ' '\n' | grep -v '^$' || true)
    else
      echo "Error: requires ss, lsof, or fuser"; exit 1
    fi
    if [ -z "$PIDS" ]; then echo "Nothing running on port $PORT"; exit 0; fi
    echo "Port $PORT is in use:"
    echo ""
    while IFS= read -r pid; do
      [ -z "$pid" ] && continue
      info=$(ps -p "$pid" -o pid=,user=,comm=,command= 2>/dev/null || true)
      if [ -n "$info" ]; then
        printf "  PID:     %s\n" "$(echo "$info" | awk '{print $1}')"
        printf "  User:    %s\n" "$(echo "$info" | awk '{print $2}')"
        printf "  Name:    %s\n" "$(echo "$info" | awk '{print $3}')"
        printf "  Command: %s\n" "$(echo "$info" | awk '{$1=$2=$3=""; sub(/^ +/, ""); print}')"
        echo ""
      fi
    done <<< "$PIDS"
    echo "$PIDS" | xargs kill -9
    echo "Killed."
    ;;

esac
